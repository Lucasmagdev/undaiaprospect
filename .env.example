# ── FONTES DE LEADS (todas opcionais, cada uma ativa mais resultados) ──────────
# ── Fontes de leads — configure pelo menos UMA para ter bons resultados ──────
# Yelp Fusion — 500 req/dia GRÁTIS, sem cartão. Ótima cobertura BR + telefones
# Cadastro: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=
# Geoapify Places — 3.000 req/dia GRÁTIS, sem cartão. Dados OSM enriquecidos
# Cadastro: https://www.geoapify.com/
GEOAPIFY_API_KEY=
# HERE Discover — 250.000 req/mês GRÁTIS, sem cartão. Excelente cobertura global
# Cadastro: https://developer.here.com/
HERE_API_KEY=
# Foursquare Places — Starter grátis, sem cartão
# Cadastro: https://developer.foursquare.com/
FOURSQUARE_API_KEY=
# Google Places — $200/mês crédito grátis (precisa de cartão). Mais completo com telefone
# Cadastro: https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=
# TTS: Kokoro (self-hosted, gratis) ou ElevenLabs (fallback)
# Kokoro rodando na VPS — prioridade se configurado
TTS_SERVER_URL=http://177.7.38.137:5050
TTS_VOICE=pf_dora
# Opcional: ElevenLabs como fallback (elevenlabs.io)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Groq — LLM gratuito para agente SDR (console.groq.com)
GROQ_API_KEY=
# Score minimo para lead ser considerado quente (0-100)
HOT_LEAD_SCORE=70
